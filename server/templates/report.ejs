<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8" />
    <style>
        body {
            font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0 40px;
            color: #333;
        }

        header {
            text-align: center;
            padding: 20px 0;
            border-bottom: 2px solid #777;
        }

        header h1 {
            margin: 0;
            font-size: 28px;
            color: #777;
        }

        .section {
            margin-top: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
            font-weight: 600;
        }

        tr:nth-child(even) {
            background-color: #fafafa;
        }

        footer {
            position: fixed;
            bottom: 20px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 12px;
            color: #777;
        }
    </style>
</head>

<body>
    <header>
        <h1>Prüfbericht</h1>
    </header>

    <div class="section">
        <h2>Berichtsdetails</h2>
        <table>
            <tr>
                <th>Titel</th>
                <td>
                    <%= report.title %>
                </td>
            </tr>
            <tr>
                <th>Beschreibung</th>
                <td>
                    <%= report.description || "Keine Beschreibung" %>
                </td>
            </tr>
            <tr>
                <th>Status</th>
                <td>
                    <%= report.status %>
                </td>
            </tr>
            <tr>
                <th>Lieferant</th>
                <td>
                    <%= supplier.titel %>
                </td>
            </tr>
            <tr>
                <th>Erstellt von</th>
                <td>
                    <%= report.createdByEmail || "" %>
                </td>
            </tr>
            <tr>
                <th>Erstellt am</th>
                <td>
                    <%= report.createdAt ? new Date(report.createdAt).toLocaleString("de-DE") : "" %>
                </td>
            </tr>
        </table>
    </div>

    <footer>Erstellt am <%= new Date().toLocaleString("de-DE") %>
    </footer>
</body>

</html>